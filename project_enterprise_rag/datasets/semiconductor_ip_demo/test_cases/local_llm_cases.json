{
  "description": "Local-LLM planner/response smoke tests for hardware-focused corpus",
  "cases": [
    {
      "id": "gpu_hbm_bottleneck",
      "plan_request": {
        "user_query": "How do I reduce GPU inference stalls caused by HBM bottlenecks and tensor core underutilization?",
